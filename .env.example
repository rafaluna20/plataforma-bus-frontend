# ─── Variables de entorno — Transporte Core Frontend ──────────────────────────
# Copiar este archivo a .env.local y completar los valores.
# NUNCA commitear .env.local (contiene claves reales) — solo este .env.example.
#
# Todas las variables que necesita el navegador deben empezar con NEXT_PUBLIC_
# (Next.js las incrusta en el bundle en build time) — nunca pongas un secreto
# real detrás de ese prefijo, ya que queda visible para cualquiera.
#
# ─── Dev / Staging / Producción ────────────────────────────────────────────────
# Lo que cambia entre entornos es a qué backend apunta el frontend:
#   Local:      NEXT_PUBLIC_API_URL=http://localhost:3000
#   Staging:    NEXT_PUBLIC_API_URL=https://api-staging.tu-dominio.pe
#   Producción: NEXT_PUBLIC_API_URL=https://api.tu-dominio.pe
# El backend de CADA entorno debe tener ese mismo dominio del frontend en su
# propia variable CORS_ORIGIN (ver backend/.env.example) — si no coinciden,
# el navegador bloquea las peticiones por CORS.

NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Mapbox (mapa interactivo de rutas/tracking) ───────────────────────────────
# Token publishable (prefijo "pk."), pensado para exponerse en el navegador.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Cloudinary (subida de imágenes de vehículos/empresas) ────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
